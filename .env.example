# Server Configuration
PORT=4501
BASE_URL=http://localhost:4501

# Application Settings
SITE_TITLE=Snake

# Security: PIN Protection (4-64 characters, leave empty to disable)
SNAKE_PIN=

# CORS Configuration
ALLOWED_ORIGINS=*

# Timezone Configuration
TZ=UTC

# Application Specific Settings
PAGE_HISTORY_COOKIE_AGE=365
MAX_ATTEMPTS=5
# Show the language picker in the header. Accepts true/false/1/0/yes/no/on/off;
# unset is treated as `true` because Snake is multilingual by design.
ENABLE_TRANSLATION=true
# Show the Super Metroid theme selector in the header.
ENABLE_THEMES=true
# Show the print button in the header.
ENABLE_PRINT=true

# Filesystem Paths
#
# SNAKE_DATA_DIR: Directory where Snake persists runtime state. The
#   high-score leaderboard is written to `${SNAKE_DATA_DIR}/leaderboard.json`
#   on every successful submission (atomic temp-file + rename). Back this
#   directory up; deleting it wipes the leaderboard.
#   Default: `./data/` (relative to the working directory).
#
# SNAKE_FRONTEND_DIR: Path to the prebuilt Trunk SPA bundle (the directory
#   that contains `index.html`, `service-worker.js`, and `Assets/`).
#   Override this if you've symlinked the bundle elsewhere or want to
#   point Snake at a custom build.
#   Default: `./frontend/dist/`.
SNAKE_DATA_DIR=data
SNAKE_FRONTEND_DIR=frontend/dist
