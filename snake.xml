<?xml version="1.0"?>
<Container version="2">
  <Name>snake</Name>
  <Repository>ghcr.io/studio2201/snake:latest</Repository>
  <Registry>https://ghcr.io/studio2201/snake</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/snake/issues</Support>
  <Project>https://github.com/studio2201/snake</Project>
  <Overview>High-performance multiplayer arcade game server and web application built in Rust.</Overview>
  <Category>Game:Arcade Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4501]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/snake.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/snake.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>High-performance multiplayer arcade game server and web application built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4501</HostPort>
        <ContainerPort>4501</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/snake</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4501</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4501" Default="4501" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4501</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/snake" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/snake</Config>
</Container>
